# ============================================================
# Bloomberg Terminal — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# All variables must be declared here with a comment explaining purpose.
# FastAPI will REFUSE TO START if required variables are missing.
# ============================================================


# ============================================================
# MOCK DATA (ADR-006)
# ============================================================

# Set USE_MOCK_DATA=true to serve all API responses from mock_data/ JSON files.
# No live API calls are made when this is enabled.
# Run scripts/generate_mock_data.py once to populate mock_data/ before enabling.
# Production default: false (live providers).
USE_MOCK_DATA=false

# Absolute path to mock_data/ directory.
# Leave empty to auto-detect via .git walk (works for standard git clones).
# Set to an absolute path if running in CI without a .git directory.
MOCK_DATA_DIR=

# Equity symbols to ingest via yfinance (comma-separated).
# Phase 1 default: top 30 S&P 500 constituents by market cap.
YFINANCE_EQUITY_SYMBOLS=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,JPM,V,JNJ,PG,UNH,MA,HD,CVX,MRK,ABBV,KO,PEP,WMT,BAC,XOM,LLY,AVGO,COST,DIS,ADBE,NFLX,CRM,AMD

# FRED macro series to ingest (comma-separated FRED series IDs).
# Phase 1 default: GDP, CPI, Fed Funds Rate, 10Y Treasury Yield, Unemployment Rate.
FRED_SERIES_IDS=GDP,CPIAUCSL,FEDFUNDS,DGS10,UNRATE


# ============================================================
# APPLICATION
# ============================================================

# Environment: development | staging | production
APP_ENV=development

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# API base URL (used by frontend to reach the API)
API_BASE_URL=https://localhost:8000

# CORS allowed origins (comma-separated, no trailing slashes).
# Local dev uses https — Vite runs with @vitejs/plugin-basic-ssl (ADR-004).
# Include http variant only if running Vite without the SSL plugin.
CORS_ALLOWED_ORIGINS=https://localhost:5173,https://localhost:3000

# Secret key for JWT signing — generate with: openssl rand -hex 32
JWT_SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET

# JWT algorithm
JWT_ALGORITHM=HS256

# Access token expiry in minutes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token expiry in days
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7


# ============================================================
# POSTGRESQL
# ============================================================

# PostgreSQL connection string (async)
DATABASE_URL=postgresql+asyncpg://terminal:terminal_dev@localhost:5432/terminal

# Sync version for Alembic migrations
SYNC_DATABASE_URL=postgresql://terminal:terminal_dev@localhost:5432/terminal

# Test database (used in integration tests — separate DB)
TEST_DATABASE_URL=postgresql+asyncpg://terminal:terminal_dev@localhost:5432/terminal_test

# Connection pool settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20


# ============================================================
# CLICKHOUSE
# ============================================================

# ClickHouse connection
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DATABASE=terminal
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ClickHouse HTTP interface (for health checks)
CLICKHOUSE_HTTP_PORT=8123


# ============================================================
# REDIS
# ============================================================

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# Celery broker URL (uses Redis)
CELERY_BROKER_URL=redis://localhost:6379/1

# Celery result backend
CELERY_RESULT_BACKEND=redis://localhost:6379/2


# ============================================================
# MARKET DATA APIs
# All sources are permanently free — see ADR-005.
# No paid tiers. No credit card required for any key below.
# ============================================================

# yfinance (Yahoo Finance) — EOD OHLCV, splits, dividends, financial statements
# No API key required. Unofficial wrapper around Yahoo Finance.
# ToS: personal/non-commercial use. Cache aggressively to reduce request volume.
# See ADR-005 for rationale and breakage mitigation strategy.
YFINANCE_BASE_URL=https://query2.finance.yahoo.com
# Self-imposed rate limit (req/min) — Yahoo has no published limit; 60/min is conservative
YFINANCE_REQUESTS_PER_MINUTE=60
# Timeout in seconds for yfinance HTTP calls
YFINANCE_TIMEOUT_SECONDS=30.0

# CoinGecko — Crypto market data, historical OHLCV
# Demo tier requires no API key: 30 calls/min, 10,000 calls/month.
# Free public tier. No credit card. See: https://www.coingecko.com/api/documentation
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
# Timeout in seconds — 15s leaves margin over CoinGecko's typical ~2s response time
COINGECKO_TIMEOUT_SECONDS=15.0
# Top-N coins by market cap to ingest per run. Default 50 covers all major assets.
COINGECKO_TOP_N_COINS=50
# CoinGecko /coins/markets max page size — defined by their API spec, not configurable
COINGECKO_MARKETS_PER_PAGE_MAX=250

# NewsAPI — Financial news aggregation
# Free developer tier: 100 req/day, 1-month history lookback.
# Sign up (free, no credit card): https://newsapi.org/register
NEWSAPI_API_KEY=REPLACE_WITH_NEWSAPI_KEY
NEWSAPI_BASE_URL=https://newsapi.org/v2

# Finnhub — Supplemental quotes and news (fallback source)
# Free tier: 60 API calls/minute, no credit card.
# Sign up (free): https://finnhub.io/register
FINNHUB_API_KEY=REPLACE_WITH_FINNHUB_KEY
FINNHUB_BASE_URL=https://finnhub.io/api/v1

# FRED API — Federal Reserve Economic Data (macro series)
# Completely free. API key required; no credit card.
# Sign up: https://fred.stlouisfed.org/docs/api/api_key.html
# ToS: no bulk archiving, no replacing FRED UX with commercial service
FRED_API_KEY=REPLACE_WITH_FRED_KEY
FRED_BASE_URL=https://api.stlouisfed.org/fred


# ============================================================
# EXTERNAL API RATE LIMITS (sourced here, never hardcoded)
# These mirror each provider's documented free tier limits.
# Update this section if free tier limits change.
# ============================================================

# yfinance — self-imposed limit (no published Yahoo limit; conservative to avoid blocks)
YFINANCE_REQUESTS_PER_MINUTE=60

# CoinGecko requests per minute (demo tier — documented limit)
COINGECKO_REQUESTS_PER_MINUTE=30

# NewsAPI requests per day (free developer tier — documented limit)
NEWSAPI_DAILY_LIMIT=100

# Finnhub requests per minute (free tier — documented limit)
FINNHUB_REQUESTS_PER_MINUTE=60

# FRED requests per day (no official limit — self-imposed soft cap out of courtesy)
FRED_DAILY_SOFT_LIMIT=500

# SEC EDGAR max requests per second (their stated fair-access limit per developer docs)
EDGAR_REQUESTS_PER_SECOND=10


# ============================================================
# CACHE TTL SETTINGS (sourced here, never hardcoded)
# ============================================================

# OHLCV cache TTL in seconds — yfinance EOD data updates once daily; 1h is safe
OHLCV_CACHE_TTL_SECONDS=3600

# Quote snapshot TTL in seconds — short enough to feel near-live without hammering API
QUOTE_CACHE_TTL_SECONDS=60

# Financial statements cache TTL — fundamentals change quarterly; 7 days is safe
FUNDAMENTALS_CACHE_TTL_SECONDS=604800

# News cache TTL — 5 minutes balances freshness with NewsAPI daily quota
NEWS_CACHE_TTL_SECONDS=300

# API endpoint limits
# Maximum symbols per bulk-quotes request. Caps memory and DB query cost.
BULK_QUOTES_MAX_SYMBOLS=50


# ============================================================
# SEC EDGAR
# ============================================================

# Required User-Agent for SEC EDGAR (must include your name + contact email)
# See: https://www.sec.gov/developer
EDGAR_USER_AGENT=Bloomberg-Terminal/1.0 your-email@example.com

# User-Agent for Finnhub and NewsAPI HTTP requests.
# Format: AppName/Version contact@yourdomain.com
# Replace the contact email before production deployment.
APP_USER_AGENT=Bloomberg-Terminal/1.0 your-email@example.com


# ============================================================
# WEBSOCKET GATEWAY
# ============================================================

# Port for the Node.js WebSocket gateway
WS_GATEWAY_PORT=3001

# Internal API URL that the WS gateway calls for auth validation.
# This is a server-side call within Docker bridge — stays HTTP (not browser-visible).
WS_GATEWAY_INTERNAL_API_URL=http://localhost:8000


# ============================================================
# FRONTEND DEV SERVER (Vite — development only, not used in prod)
# ============================================================

# Target for Vite's /api proxy — server-side proxy leg, browser never sees this URL.
# Stays HTTP even though the browser connects to https://localhost:5173 (ADR-004).
VITE_DEV_API_PROXY_TARGET=http://localhost:8000

# Target for Vite's /ws proxy — server-side proxy leg, stays WS (not WSS).
VITE_DEV_WS_PROXY_TARGET=ws://localhost:3001

# Binance WebSocket base URL
BINANCE_WS_BASE_URL=wss://stream.binance.com:9443

# Coinbase WebSocket base URL
COINBASE_WS_BASE_URL=wss://advanced-trade-ws.coinbase.com


# ============================================================
# CELERY / WORKER
# ============================================================

# Celery worker concurrency (number of parallel worker processes)
CELERY_WORKER_CONCURRENCY=4

# Celery task time limit in seconds (hard kill)
CELERY_TASK_TIME_LIMIT=300

# Celery task soft time limit in seconds (raises SoftTimeLimitExceeded)
CELERY_TASK_SOFT_TIME_LIMIT=240

# Max retries for ingestion tasks (FRED, yfinance, CoinGecko, EDGAR, news)
CELERY_TASK_MAX_RETRIES=3

# Max retries for lightweight tasks (alert evaluator, quota report)
CELERY_LIGHTWEIGHT_TASK_MAX_RETRIES=1

# Market close time for EOD ingestion trigger (ET timezone, 24h format)
MARKET_CLOSE_TIME_ET=17:00


# ============================================================
# EMAIL (Alerts delivery)
# ============================================================

# Email provider: sendgrid | resend | smtp
EMAIL_PROVIDER=sendgrid

# SendGrid API key (if using SendGrid)
SENDGRID_API_KEY=REPLACE_WITH_SENDGRID_KEY

# Resend API key (if using Resend)
RESEND_API_KEY=REPLACE_WITH_RESEND_KEY

# From email address for alert notifications
EMAIL_FROM_ADDRESS=alerts@yourdomain.com
EMAIL_FROM_NAME=Bloomberg Terminal Alerts


# ============================================================
# MONITORING
# ============================================================

# Sentry DSN for error tracking (frontend and backend)
SENTRY_DSN=

# Sentry environment tag
SENTRY_ENVIRONMENT=development

# Grafana Cloud metrics push URL (optional)
GRAFANA_PUSH_URL=


# ============================================================
# STORAGE (future: filing documents, notebooks)
# ============================================================

# S3-compatible storage for filing documents
# Use MinIO locally: http://localhost:9000
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_FILINGS=terminal-filings
S3_BUCKET_NOTEBOOKS=terminal-notebooks
S3_REGION=us-east-1


# ============================================================
# FRONTEND (Vite env vars — must be prefixed with VITE_)
# ============================================================

# API base URL accessible from the browser. Must match the protocol the browser
# connects on — https in local dev (ADR-004), https in production.
VITE_API_BASE_URL=https://localhost:8000/api/v1

# WebSocket gateway URL accessible from the browser.
# wss:// required when the page is served over https (mixed-content policy).
VITE_WS_URL=wss://localhost:3001

# Sentry DSN for frontend error tracking
VITE_SENTRY_DSN=

# App version (injected at build time)
VITE_APP_VERSION=0.0.1
