{
  "name": "@terminal/web",
  "version": "0.0.1",
  "private": true,
  "description": "Bloomberg Terminal — React SPA",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "test": "vitest run",
    "test:unit": "vitest run --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "clean": "rm -rf dist .vite"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.32.0",
    "@tanstack/react-router": "^1.30.0",
    "@terminal/ui-components": "workspace:^",
    "cmdk": "^1.0.0",
    "d3": "^7.9.0",
    "dockview-react": "^5.2.0",
    "fuse.js": "^7.0.0",
    "lightweight-charts": "^4.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-resizable-panels": "^2.0.0",
    "recharts": "^2.12.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@ag-grid-community/core": "^31.2.0",
    "@ag-grid-community/react": "^31.2.0",
    "@playwright/test": "^1.44.0",
    "@terminal/eslint-config": "workspace:*",
    "@terminal/types": "workspace:*",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^15.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/d3": "^7.4.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.5.0",
    "autoprefixer": "^10.4.0",
    "jsdom": "^24.0.0",
    "playwright": "^1.44.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.5.0"
  }
}
