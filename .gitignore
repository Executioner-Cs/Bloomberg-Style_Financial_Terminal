# ============================================================
# Bloomberg Terminal — .gitignore
# ============================================================

# --- SECRETS (NEVER COMMIT) ---------------------------------
.env
.env.local
.env.production
.env.staging
*.pem
*.key
*.p12
*.pfx
secrets/

# --- Node / pnpm --------------------------------------------
node_modules/
.pnpm-store/
dist/
build/
.turbo/
*.tsbuildinfo
.cache/

# --- Python -------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
.python-version
*.egg-info/
dist/
build/
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
coverage.xml
*.cover

# --- Databases & Data ---------------------------------------
*.sqlite
*.db
*.duckdb
data/
dumps/
backups/

# --- Docker -------------------------------------------------
# (keep docker-compose files, ignore local overrides)
docker-compose.override.yml

# --- AI Tools -----------------------------------------------
.claude/
.cursor/

# --- Editors ------------------------------------------------
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- OS -----------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Desktop.ini

# --- Logs ---------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Test Artifacts -----------------------------------------
coverage/
test-results/
playwright-report/
e2e/screenshots/
e2e/videos/

# --- Terraform ----------------------------------------------
infrastructure/terraform/.terraform/
infrastructure/terraform/*.tfstate
infrastructure/terraform/*.tfstate.backup
infrastructure/terraform/.terraform.lock.hcl
infrastructure/terraform/tfplan

# --- Build Outputs ------------------------------------------
apps/web/dist/
apps/web/.vite/
packages/*/dist/
services/*/dist/

# --- Jupyter (future notebooks) -----------------------------
.ipynb_checkpoints/
*.ipynb

# --- Generated Files ----------------------------------------
packages/types/src/*.generated.ts
services/api/src/openapi.json

# --- Graphify (knowledge graph tool output) -----------------
# graphify generates HTML/JSON reports into graphify-out/.
# Source is in .graphifyignore. Output is never committed.
graphify-out/
